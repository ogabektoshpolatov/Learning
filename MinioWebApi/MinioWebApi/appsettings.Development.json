{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // ─── MinIO Connection Settings ───────────────────────────────────────────────
  // These values must match what you set when starting MinIO locally
  // Docker example:
  //   docker run -p 9000:9000 -p 9001:9001
  //   -e MINIO_ROOT_USER=admin
  //   -e MINIO_ROOT_PASSWORD=password123
  //   -v C:/minio-data:/data
  //   quay.io/minio/minio server /data --console-address ":9001"
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",  // ← MinIO's built-in default
    "SecretKey": "minioadmin",   // ← MinIO's built-in default
    "BucketName": "my-files",
    "UseSSL": false
  },
  "AllowedHosts": "*"
}